# CoinDCX API (Required for live trading)
COINDCX_API_KEY=your_coindcx_api_key_here
COINDCX_API_SECRET=your_coindcx_api_secret_here

# Binance API (Fallback exchange)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Ollama LLM
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_FALLBACK_MODEL=mistral

# Trading Mode
PAPER_MODE=true
PAPER_BALANCE=10000

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Risk Defaults
MAX_POSITION_PCT=5
MAX_OPEN_TRADES=5
DAILY_LOSS_LIMIT_PCT=3
DEFAULT_STOP_LOSS_PCT=1.5
DEFAULT_TAKE_PROFIT_PCT=3.0
TRAILING_STOP_ACTIVATE_PCT=1.5
TRAILING_STOP_TRAIL_PCT=0.5
